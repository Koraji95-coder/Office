<Application x:Class="DailyDesk.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <SolidColorBrush x:Key="BrushWindow" Color="#07090D" />
        <SolidColorBrush x:Key="BrushPanel" Color="#11161D" />
        <SolidColorBrush x:Key="BrushPanelRaised" Color="#181F29" />
        <SolidColorBrush x:Key="BrushPanelStrong" Color="#202A36" />
        <SolidColorBrush x:Key="BrushBorder" Color="#253040" />
        <SolidColorBrush x:Key="BrushCopper" Color="#C6A46D" />
        <SolidColorBrush x:Key="BrushCopperSoft" Color="#D4B98B" />
        <SolidColorBrush x:Key="BrushVerdigris" Color="#5B8B7D" />
        <SolidColorBrush x:Key="BrushSignalBlue" Color="#7390FF" />
        <SolidColorBrush x:Key="BrushText" Color="#EFE8DC" />
        <SolidColorBrush x:Key="BrushMuted" Color="#A79E91" />
    </Application.Resources>
</Application>
