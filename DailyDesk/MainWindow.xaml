                                            <Button Content="Queue" Background="#241A10" BorderBrush="{StaticResource BrushCopper}" Command="{Binding QueueSuggestedActionCommand}" CommandParameter="{Binding SelectedInboxSuggestion}" Visibility="{Binding ShowSuggestionQueueActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <Button Content="Run now" Command="{Binding RunSuggestedActionNowCommand}" CommandParameter="{Binding SelectedInboxSuggestion}" Visibility="{Binding ShowSuggestionQueueActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <Button Content="Dismiss" Command="{Binding DeferSuggestedActionCommand}" CommandParameter="{Binding SelectedInboxSuggestion}" Visibility="{Binding ShowSuggestionQueueActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <Button Content="Queue" Background="#241A10" BorderBrush="{StaticResource BrushCopper}" Command="{Binding QueueSuggestedActionCommand}" CommandParameter="{Binding SelectedInboxSuggestion}" Visibility="{Binding ShowApprovedFollowThroughActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <Button Content="Run now" Command="{Binding RunSuggestedActionNowCommand}" CommandParameter="{Binding SelectedInboxSuggestion}" Visibility="{Binding ShowApprovedFollowThroughActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <Button Content="Run now" Command="{Binding RunSuggestedActionNowCommand}" CommandParameter="{Binding SelectedInboxSuggestion}" Visibility="{Binding ShowQueuedWorkActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        </WrapPanel>
                                        <Border Margin="0,20,0,0"
                                                Padding="14"
                                                Background="#0D1218"
                                                BorderBrush="{StaticResource BrushBorder}"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                Visibility="{Binding SelectedInboxSuggestion.HasLatestResult, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Text="Latest result" Style="{StaticResource SectionTitleStyle}" />
                                                <TextBlock Text="{Binding SelectedInboxSuggestion.LatestResultSummary}"
                                                           Margin="0,6,0,0"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding SelectedInboxSuggestion.LatestResultDetail}"
                                                           Margin="0,10,0,0"
                                                           Foreground="{StaticResource BrushMuted}"
                                                           TextWrapping="Wrap" />
                                                <ItemsControl Margin="0,12,0,0"
                                                              ItemsSource="{Binding SelectedInboxSuggestion.LatestResultSources}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}"
                                                                       Margin="0,0,0,8"
                                                                       Foreground="{StaticResource BrushCopperSoft}"
                                                                       TextWrapping="Wrap" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="0,20,0,0"
                                                Padding="14"
                                                Background="#0D1218"
                                                BorderBrush="{StaticResource BrushBorder}"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <StackPanel>
                                                <TextBlock Text="Execution history" Style="{StaticResource SectionTitleStyle}" />
                                                <TextBlock Text="{Binding SuggestionExecutionHistorySummary}"
                                                           Margin="0,6,0,12"
                                                           Foreground="{StaticResource BrushMuted}"
                                                           TextWrapping="Wrap" />
                                                <ItemsControl ItemsSource="{Binding SuggestionExecutionHistory}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type models:OperatorActivityRecord}">
                                                            <Border Margin="0,0,0,10"
                                                                    Padding="12"
                                                                    Background="#121924"
                                                                    BorderBrush="{StaticResource BrushBorder}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="12">
                                                                <StackPanel>
                                                                    <DockPanel LastChildFill="False">
                                                                        <TextBlock DockPanel.Dock="Left"
                                                                                   Text="{Binding DisplayEventLabel}"
                                                                                   FontWeight="SemiBold" />
                                                                        <TextBlock DockPanel.Dock="Right"
                                                                                   Text="{Binding DisplayMeta}"
                                                                                   Foreground="{StaticResource BrushMuted}"
                                                                                   FontSize="11"
                                                                                   FontFamily="IBM Plex Mono" />
                                                                    </DockPanel>
                                                                    <TextBlock Text="{Binding Summary}"
                                                                               Margin="0,6,0,0"
                                                                               Foreground="{StaticResource BrushMuted}"
                                                                               TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Library">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Border Style="{StaticResource RaisedPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="Knowledge Library" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Text="{Binding LearningLibrarySummary}" Margin="0,6,0,12" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" />
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <Button Content="Import files"
                                                        Margin="0,0,10,0"
                                                        Command="{Binding ImportKnowledgeFilesCommand}" />
                                                <Button Content="Open folder"
                                                        Command="{Binding OpenKnowledgeFolderCommand}" />
                                            </StackPanel>
                                            <TextBlock Text="Knowledge sources"
                                                       Margin="0,0,0,8"
                                                       Foreground="{StaticResource BrushCopperSoft}"
                                                       FontFamily="IBM Plex Mono"
                                                       FontSize="11" />
                                            <ItemsControl ItemsSource="{Binding KnowledgeSourceSummaries}"
                                                          Margin="0,0,0,12">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   Margin="0,0,0,8"
                                                                   Foreground="{StaticResource BrushMuted}"
                                                                   TextWrapping="Wrap" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <ItemsControl ItemsSource="{Binding ImportedDocumentSummaries}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource RaisedPanel}">
                                        <StackPanel>
                                            <TextBlock Text="Learning Topics" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Text="{Binding LearningProfileSummary}" Margin="0,6,0,12" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" />
                                            <ItemsControl ItemsSource="{Binding LearningTopicSummaries}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <GridSplitter Grid.Column="1"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          ResizeDirection="Columns"
                                          ResizeBehavior="PreviousAndNext"
                                          ShowsPreview="True"
                                          Background="#13202E" />

                            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Border Style="{StaticResource RaisedPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="Training Memory" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Text="{Binding TrainingOverallSummary}" Margin="0,6,0,12" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding TrainingSession.HistorySummary}" Foreground="{StaticResource BrushCopperSoft}" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding TrainingSession.ChecklistSummary}" Margin="0,10,0,0" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" />
                                            <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding RecentPracticeSummaries}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource RaisedPanel}">
                                        <StackPanel>
                                            <TextBlock Text="Recent Research" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Text="{Binding ResearchSummary}" Margin="0,6,0,12" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" />
                                            <ItemsControl ItemsSource="{Binding ResearchSources}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type models:ResearchSource}">
                                                        <TextBlock Margin="0,0,0,8" TextWrapping="Wrap">
                                                            <Run Text="{Binding Title}" /><Run Text=" | " /><Run Text="{Binding SourceLabel}" Foreground="{StaticResource BrushCopperSoft}" />
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Guide">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Style="{StaticResource RaisedPanel}"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="{Binding AgentReplyGuideTitle}" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding AgentReplyGuideSummary}"
                                               Margin="0,6,0,10"
                                               Foreground="{StaticResource BrushMuted}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding AgentReplyGuidePathSummary}"
                                               Foreground="{StaticResource BrushCopperSoft}"
                                               FontFamily="IBM Plex Mono"
                                               FontSize="11"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource RaisedPanel}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding AgentReplyGuideSections}"
                                                  ItemTemplate="{StaticResource GuideSectionTemplate}" />
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter Grid.Column="3"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True"
                          Background="#13202E" />

            <Border Grid.Column="4" Style="{StaticResource Panel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource RaisedPanel}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Suite Signals" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="{Binding SuiteDoctorSummary}" Margin="0,8,0,0" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SuiteDoctorLeadDetail}" Margin="0,8,0,0" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding WorkshopSignalSummary}" Margin="0,10,0,0" Foreground="{StaticResource BrushCopperSoft}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource RaisedPanel}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Office Parameters" Style="{StaticResource SectionTitleStyle}" />
                                <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding OfficeParameterCards}" ItemTemplate="{StaticResource FocusCardTemplate}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource RaisedPanel}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Inbox Preview" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="{Binding ApprovalInboxSummary}" Margin="0,6,0,12" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" />
                                <ItemsControl ItemsSource="{Binding PendingApprovalSuggestions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:SuggestedAction}">
                                            <Border Margin="0,0,0,10" Padding="12" Background="#0D1218" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="12">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding SourceAgent}" Margin="0,6,0,0" Foreground="{StaticResource BrushCopperSoft}" FontFamily="IBM Plex Mono" FontSize="11" />
                                                    <Button Content="Open In Inbox" Margin="0,10,0,0" Command="{Binding DataContext.OpenSuggestionInInboxCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Approved next"
                                           Margin="0,12,0,0"
                                           Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="{Binding ApprovedSuggestionsSummary}"
                                           Margin="0,6,0,12"
                                           Foreground="{StaticResource BrushMuted}"
                                           TextWrapping="Wrap" />
                                <ItemsControl ItemsSource="{Binding ApprovedSuggestions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:SuggestedAction}">
                                            <Border Margin="0,0,0,10" Padding="12" Background="#0D1218" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="12">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding SourceAgent}" Margin="0,6,0,0" Foreground="{StaticResource BrushCopperSoft}" FontFamily="IBM Plex Mono" FontSize="11" />
                                                    <Button Content="Open In Inbox" Margin="0,10,0,0" Command="{Binding DataContext.OpenSuggestionInInboxCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource RaisedPanel}">
                            <StackPanel>
                                <TextBlock Text="Job Feed" Style="{StaticResource SectionTitleStyle}" />
                                <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding JobActivities}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:JobActivityItem}">
                                            <Border Margin="0,0,0,10" Padding="12" Background="#0D1218" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="12">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding DisplayMeta}" Margin="0,4,0,0" Foreground="{StaticResource BrushMuted}" FontSize="11" FontFamily="IBM Plex Mono" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Summary}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
