                                            Padding="14"
                                            Background="#0D1218"
                                            BorderBrush="{StaticResource BrushBorder}"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Left"
                                                           Text="{Binding Name}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />
                                                <Border DockPanel.Dock="Right"
                                                        Padding="8,4"
                                                        Margin="12,0,0,0"
                                                        Background="#171E28"
                                                        BorderBrush="{Binding Accent}"
                                                        BorderThickness="1"
                                                        CornerRadius="999">
                                                    <TextBlock Text="{Binding Status}"
                                                               FontSize="11"
                                                               FontFamily="IBM Plex Mono"
                                                               Foreground="{Binding Accent}" />
                                                </Border>
                                            </DockPanel>
                                            <TextBlock Text="{Binding Role}"
                                                       Margin="0,8,0,0"
                                                       Foreground="{StaticResource BrushMuted}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Model}"
                                                       Margin="0,10,0,0"
                                                       Foreground="{StaticResource BrushCopperSoft}"
                                                       FontFamily="IBM Plex Mono"
                                                       FontSize="11"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Mode}"
                                                       Margin="0,8,0,0"
                                                       Foreground="{StaticResource BrushMuted}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding ThreadSummary}"
                                                       Margin="0,8,0,0"
                                                       Foreground="{StaticResource BrushMuted}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                            <Setter TargetName="Card" Property="BorderBrush" Value="{Binding Accent}" />
                                            <Setter TargetName="Card" Property="Background" Value="#171F29" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True"
                          Background="#13202E" />

            <Border Grid.Column="2" Style="{StaticResource Panel}">
                <TabControl SelectedIndex="{Binding SelectedPrimaryTabIndex, Mode=TwoWay}">
                    <TabItem Header="Office">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Style="{StaticResource RaisedPanel}"
                                    Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedDesk.Name, TargetNullValue=Choose a desk}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding SelectedDesk.Role}"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource BrushCopperSoft}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding SelectedDeskSummary}"
                                               Margin="0,12,0,0"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding SelectedDeskContextSummary}"
                                               Margin="0,8,0,0"
                                               Foreground="{StaticResource BrushMuted}"
                                               TextWrapping="Wrap" />

                                    <WrapPanel Margin="0,14,0,0">
                                        <Border Padding="10,6"
                                                Margin="0,0,10,10"
                                                Background="#121924"
                                                BorderBrush="{StaticResource BrushBorder}"
                                                BorderThickness="1"
                                                CornerRadius="999">
                                            <TextBlock Text="{Binding SelectedDesk.Model}"
                                                       FontSize="11"
                                                       FontFamily="IBM Plex Mono"
                                                       Foreground="{StaticResource BrushCopperSoft}" />
                                        </Border>
                                        <Border Padding="10,6"
                                                Margin="0,0,10,10"
                                                Background="#121924"
                                                BorderBrush="{StaticResource BrushBorder}"
                                                BorderThickness="1"
                                                CornerRadius="999">
                                            <TextBlock Text="{Binding SelectedDesk.Mode}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource BrushMuted}" />
                                        </Border>
                                        <Border Padding="10,6"
                                                Margin="0,0,10,10"
                                                Background="#121924"
                                                BorderBrush="{StaticResource BrushBorder}"
                                                BorderThickness="1"
                                                CornerRadius="999">
                                            <TextBlock Text="{Binding SelectedDesk.Focus}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource BrushMuted}" />
                                        </Border>
                                    </WrapPanel>

                                    <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding DeskQuickActions}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:DeskAction}">
                                                <Button Content="{Binding Label}" Command="{Binding DataContext.RunDeskActionCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource RaisedPanel}">
                                    <DockPanel LastChildFill="True">
                                        <StackPanel DockPanel.Dock="Top">
                                            <TextBlock Text="Desk Thread" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Text="{Binding SelectedDeskThreadSummary}"
                                                       Margin="0,6,0,12"
                                                       Foreground="{StaticResource BrushMuted}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding DeskMessages}" ItemTemplate="{StaticResource DeskMessageTemplate}" />
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>

                                <GridSplitter Grid.Column="1"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              ResizeDirection="Columns"
                                              ResizeBehavior="PreviousAndNext"
                                              ShowsPreview="True"
                                              Background="#13202E" />

                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="14" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Style="{StaticResource RaisedPanel}">
                                        <StackPanel>
                                            <TextBlock Text="Workbench" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Text="Current desk outputs, signal ties, and active context."
                                                       Margin="0,6,0,14"
                                                       Foreground="{StaticResource BrushMuted}"
                                                       TextWrapping="Wrap" />
                                            <ItemsControl ItemsSource="{Binding DeskPanels}" ItemTemplate="{StaticResource FocusCardTemplate}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="2" Style="{StaticResource RaisedPanel}">
                                        <DockPanel LastChildFill="True">
                                            <StackPanel DockPanel.Dock="Top">
                                                <TextBlock Text="Suggested Moves" Style="{StaticResource SectionTitleStyle}" />
                                                <TextBlock Text="{Binding SuggestionMemorySummary}"
                                                           Margin="0,6,0,12"
                                                           Foreground="{StaticResource BrushMuted}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding DeskSuggestions}"
                                                              ItemTemplate="{StaticResource DeskSuggestionTemplate}" />
                                            </ScrollViewer>
                                        </DockPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                            <Border Grid.Row="2"
                                    Style="{StaticResource RaisedPanel}"
                                    Margin="0,14,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedDeskPromptHint}" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" />
                                        <TextBox Margin="0,12,0,0"
                                                 MinHeight="110"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding DeskMessageDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Margin="16,32,0,0"
                                            VerticalAlignment="Top"
                                            Background="#241A10"
                                            BorderBrush="{StaticResource BrushCopper}"
                                            Content="Send To Desk"
                                            Command="{Binding SendDeskMessageCommand}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Inbox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="340" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource RaisedPanel}">
                                <DockPanel LastChildFill="True">
                                    <StackPanel DockPanel.Dock="Top">
                                        <TextBlock Text="Work Inbox" Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="Approvals stay separate from self-serve suggestions and queued follow-through."
                                                   Margin="0,6,0,14"
                                                   Foreground="{StaticResource BrushMuted}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <ScrollViewer VerticalScrollBarVisibility="Visible"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  PanningMode="VerticalOnly">
                                        <StackPanel Margin="0,0,10,28">
                                            <TextBlock Text="Approvals"
                                                       Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Text="{Binding ApprovalInboxSummary}"
                                                       Margin="0,6,0,12"
                                                       Foreground="{StaticResource BrushMuted}"
                                                       TextWrapping="Wrap" />
                                            <ListBox ItemsSource="{Binding PendingApprovalSuggestions}"
                                                     SelectedValuePath="Id"
                                                     SelectedValue="{Binding SelectedInboxSuggestionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                     ItemTemplate="{StaticResource InboxSuggestionCardTemplate}" />

                                            <TextBlock Text="Suggestions"
                                                       Margin="0,14,0,0"
                                                       Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Text="{Binding SuggestionsSummary}"
                                                       Margin="0,6,0,12"
                                                       Foreground="{StaticResource BrushMuted}"
                                                       TextWrapping="Wrap" />
                                            <ListBox ItemsSource="{Binding OpenSuggestions}"
                                                     SelectedValuePath="Id"
                                                     SelectedValue="{Binding SelectedInboxSuggestionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                     ItemTemplate="{StaticResource InboxSuggestionCardTemplate}" />

                                            <TextBlock Text="Approved next"
                                                       Margin="0,14,0,0"
                                                       Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Text="{Binding ApprovedSuggestionsSummary}"
                                                       Margin="0,6,0,12"
                                                       Foreground="{StaticResource BrushMuted}"
                                                       TextWrapping="Wrap" />
                                            <ListBox ItemsSource="{Binding ApprovedSuggestions}"
                                                     SelectedValuePath="Id"
                                                     SelectedValue="{Binding SelectedInboxSuggestionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                     ItemTemplate="{StaticResource InboxSuggestionCardTemplate}" />

                                            <TextBlock Text="Queued work"
                                                       Margin="0,14,0,0"
                                                       Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Text="{Binding QueuedWorkSummary}"
                                                       Margin="0,6,0,12"
                                                       Foreground="{StaticResource BrushMuted}"
                                                       TextWrapping="Wrap" />
                                            <ListBox ItemsSource="{Binding QueuedWorkSuggestions}"
                                                     SelectedValuePath="Id"
                                                     SelectedValue="{Binding SelectedInboxSuggestionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                     ItemTemplate="{StaticResource InboxSuggestionCardTemplate}" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>

                            <GridSplitter Grid.Column="1"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          ResizeDirection="Columns"
                                          ResizeBehavior="PreviousAndNext"
                                          ShowsPreview="True"
                                          Background="#13202E" />

                            <Border Grid.Column="2" Style="{StaticResource RaisedPanel}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              PanningMode="VerticalOnly"
                                              PreviewMouseWheel="NestedScrollViewer_OnPreviewMouseWheel">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.Title, TargetNullValue=Select a suggestion}"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.SourceAgent}"
                                                   Margin="0,6,0,0"
                                                   Foreground="{StaticResource BrushCopperSoft}"
                                                   FontFamily="IBM Plex Mono"
                                                   FontSize="11" />
                                        <TextBlock Text="{Binding SelectedInboxLaneSummary}"
                                                   Margin="0,10,0,0"
                                                   Foreground="{StaticResource BrushMuted}"
                                                   TextWrapping="Wrap" />
                                        <Border Margin="0,12,0,0"
                                                Padding="8,4"
                                                Background="#14211A"
                                                BorderBrush="#2E7851"
                                                BorderThickness="1"
                                                CornerRadius="999"
                                                HorizontalAlignment="Left"
                                                Visibility="{Binding SelectedInboxSuggestion.WasAutoStaged, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="Auto-staged from self-serve research"
                                                       FontSize="11"
                                                       FontFamily="IBM Plex Mono"
                                                       Foreground="#9FD0B2" />
                                        </Border>

                                        <WrapPanel Margin="0,14,0,0">
                                            <Border Padding="10,6"
                                                    Margin="0,0,10,10"
                                                    Background="#121924"
                                                    BorderBrush="{StaticResource BrushBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="999">
                                                <TextBlock Text="{Binding SelectedInboxSuggestion.Priority, StringFormat=Priority: {0}}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource BrushMuted}" />
                                            </Border>
                                            <Border Padding="10,6"
                                                    Margin="0,0,10,10"
                                                    Background="#121924"
                                                    BorderBrush="{StaticResource BrushBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="999">
                                                <TextBlock Text="{Binding SelectedInboxSuggestion.ActionType, StringFormat=Type: {0}}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource BrushMuted}" />
                                            </Border>
                                            <Border Padding="10,6"
                                                    Margin="0,0,10,10"
                                                    Background="#121924"
                                                    BorderBrush="{StaticResource BrushBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="999">
                                                <TextBlock Text="{Binding SelectedInboxSuggestion.LinkedArea, StringFormat=Area: {0}}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource BrushMuted}" />
                                            </Border>
                                        </WrapPanel>

                                        <TextBlock Text="{Binding SelectedInboxSuggestion.Rationale}" Margin="0,14,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.ExpectedBenefit, StringFormat=Expected benefit: {0}}" Margin="0,14,0,0" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.WhatYouLearn, StringFormat=What you learn: {0}}" Margin="0,8,0,0" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.ProductImpact, StringFormat=Product impact: {0}}" Margin="0,8,0,0" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.CareerValue, StringFormat=Career value: {0}}" Margin="0,8,0,0" Foreground="{StaticResource BrushMuted}" TextWrapping="Wrap" />
                                        <TextBlock Text="Reason" Margin="0,18,0,6" Foreground="{StaticResource BrushCopperSoft}" Visibility="{Binding ShowApprovalDecisionActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock Text="Required before you approve, defer, or reject this suggestion."
                                                   Margin="0,0,0,8"
                                                   Foreground="{StaticResource BrushMuted}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding ShowApprovalDecisionActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBox Text="{Binding SelectedInboxSuggestion.OutcomeReasonInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding ShowApprovalDecisionActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBlock Text="Outcome note" Margin="0,14,0,6" Foreground="{StaticResource BrushCopperSoft}" Visibility="{Binding ShowApprovalDecisionActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        <TextBox MinHeight="100" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding SelectedInboxSuggestion.OutcomeNoteInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding ShowApprovalDecisionActions, Converter={StaticResource BoolToVisibilityConverter}}" />
