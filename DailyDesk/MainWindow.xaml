<Window x:Class="DailyDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:DailyDesk.Models;assembly=DailyDesk.Core"
        Title="Office"
        Icon="Assets/office.ico"
        Width="1680"
        Height="990"
        MinWidth="1200"
        MinHeight="780"
        Background="{StaticResource BrushWindow}"
        FontFamily="Plus Jakarta Sans"
        Foreground="{StaticResource BrushText}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- ═══════════════════════ CONTROL TEMPLATES ═══════════════════════ -->

        <ControlTemplate x:Key="ButtonChromeTemplate" TargetType="Button">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8"
                    SnapsToDevicePixels="True">
                <ContentPresenter Margin="{TemplateBinding Padding}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  RecognizesAccessKey="True" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource BrushCopper}" />
                    <Setter TargetName="Chrome" Property="Background" Value="#1A2230" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Chrome" Property="Background" Value="#241A10" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Chrome" Property="Opacity" Value="0.42" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="AccentButtonTemplate" TargetType="Button">
            <Border x:Name="Chrome"
                    Background="#1C1610"
                    BorderBrush="{StaticResource BrushCopper}"
                    BorderThickness="1"
                    CornerRadius="8"
                    SnapsToDevicePixels="True">
                <ContentPresenter Margin="{TemplateBinding Padding}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  RecognizesAccessKey="True" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Chrome" Property="Background" Value="#2A1E12" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Chrome" Property="Background" Value="#342414" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Chrome" Property="Opacity" Value="0.42" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Width="8" Background="Transparent">
                <Track x:Name="PART_Track"
                       IsDirectionReversed="True"
                       Focusable="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.LineUpCommand" Focusable="False" Opacity="0" IsTabStop="False" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.LineDownCommand" Focusable="False" Opacity="0" IsTabStop="False" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Height="8" Background="Transparent">
                <Track x:Name="PART_Track" Focusable="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.LineLeftCommand" Focusable="False" Opacity="0" IsTabStop="False" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.LineRightCommand" Focusable="False" Opacity="0" IsTabStop="False" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <!-- ═══════════════════════ GLOBAL STYLES ═══════════════════════ -->

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource BrushText}" />
            <Setter Property="Background" Value="{StaticResource BrushPanelRaised}" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template" Value="{StaticResource ButtonChromeTemplate}" />
        </Style>

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource BrushCopperSoft}" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template" Value="{StaticResource AccentButtonTemplate}" />
        </Style>

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushPanel}" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="RaisedPanel" TargetType="Border" BasedOn="{StaticResource Panel}">
            <Setter Property="Background" Value="{StaticResource BrushPanelRaised}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#0C1118" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0A0F16" />
            <Setter Property="Foreground" Value="{StaticResource BrushText}" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="CaretBrush" Value="{StaticResource BrushCopper}" />
            <Setter Property="SelectionBrush" Value="{StaticResource BrushSignalBlue}" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="MinWidth" Value="8" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbChrome"
                                Margin="1"
                                Background="#2A3646"
                                CornerRadius="4"
                                Opacity="0.6" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="#3D4F64" />
                                <Setter TargetName="ThumbChrome" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="{StaticResource BrushCopper}" />
                                <Setter TargetName="ThumbChrome" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource BrushCopper}" />
            <Setter Property="Background" Value="#141B24" />
            <Setter Property="Height" Value="3" />
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="8" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}" />
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderlessTabControlStyle" TargetType="TabControl">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <ContentPresenter ContentSource="SelectedContent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════ SIDEBAR STYLES ═══════════════════════ -->

        <Style x:Key="SidebarNavListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="SidebarNavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Border x:Name="Indicator"
                                    Width="3"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Height="24"
                                    CornerRadius="0,2,2,0"
                                    Background="Transparent" />
                            <Border x:Name="NavBg"
                                    Margin="6,0,6,0"
                                    Padding="0,10"
                                    Background="Transparent"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Indicator" Property="Background" Value="{StaticResource BrushCopper}" />
                                <Setter TargetName="NavBg" Property="Background" Value="#141B24" />
                                <Setter Property="Foreground" Value="{StaticResource BrushCopperSoft}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBg" Property="Background" Value="#111820" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        </Style>

        <Style x:Key="SectionSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MetaBadge" TargetType="Border">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="#0E141C" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style x:Key="AccentBadge" TargetType="Border">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="#1C1610" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushCopperMuted}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <!-- ═══════════════════════ DATA TEMPLATES ═══════════════════════ -->

        <DataTemplate x:Key="GuideSectionBlockTemplate" DataType="{x:Type models:GuideSectionBlock}">
            <Border Margin="{Binding Margin}"
                    Padding="{Binding Padding}"
                    Background="{Binding Background}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="{Binding BorderThickness}"
                    CornerRadius="{Binding CornerRadius}">
                <TextBlock Text="{Binding Text}"
                           Foreground="{Binding Foreground}"
                           FontFamily="{Binding FontFamily}"
                           FontSize="{Binding FontSize}"
                           FontWeight="{Binding FontWeight}"
                           TextWrapping="Wrap" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="GuideSectionTemplate" DataType="{x:Type models:GuideSection}">
            <Border Margin="0,0,0,12"
                    Padding="16"
                    Background="{Binding BackgroundBrush}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{Binding AccentBrush}"
                               TextWrapping="Wrap" />
                    <Border Margin="0,8,0,10"
                            Height="2"
                            Width="48"
                            HorizontalAlignment="Left"
                            Background="{Binding AccentBrush}"
                            CornerRadius="999"
                            Opacity="0.6" />
                    <ItemsControl ItemsSource="{Binding Blocks}"
                                  ItemTemplate="{StaticResource GuideSectionBlockTemplate}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="FocusCardTemplate" DataType="{x:Type models:FocusCard}">
            <Border Margin="0,0,0,8"
                    Padding="12"
                    Background="#0C1118"
                    BorderBrush="{Binding Accent}"
                    BorderThickness="0,0,0,0"
                    CornerRadius="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{Binding Accent}"
                            CornerRadius="2"
                            Margin="0,2,10,2"
                            Width="3" />
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Tag}"
                                   Foreground="{Binding Accent}"
                                   FontSize="10"
                                   FontFamily="IBM Plex Mono"
                                   Opacity="0.8" />
                        <TextBlock Text="{Binding Title}"
                                   Margin="0,6,0,0"
                                   FontSize="13.5"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Summary}"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource BrushMuted}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DeskMessageTemplate" DataType="{x:Type models:DeskMessageRecord}">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Avatar"
                        Grid.Column="0"
                        Width="32" Height="32"
                        CornerRadius="16"
                        Background="#1A2230"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1"
                        Margin="0,0,10,0"
                        VerticalAlignment="Top">
                    <TextBlock x:Name="AvatarText"
                               Text="AI"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrushSignalBlue}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <Border x:Name="Bubble"
                        Grid.Column="1"
                        Padding="14,10"
                        Background="#0E141C"
                        BorderBrush="{StaticResource BrushBorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="4,12,12,12"
                        MaxWidth="640"
                        HorizontalAlignment="Left">
                    <StackPanel>
                        <TextBlock Text="{Binding Meta}"
                                   Foreground="{StaticResource BrushMuted}"
                                   FontSize="10.5"
                                   FontFamily="IBM Plex Mono" />
                        <TextBlock Text="{Binding Content}"
                                   Margin="0,6,0,0"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   LineHeight="20" />
                    </StackPanel>
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsUser}" Value="True">
                    <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right" />
                    <Setter TargetName="Bubble" Property="Background" Value="#1A1610" />
                    <Setter TargetName="Bubble" Property="BorderBrush" Value="{StaticResource BrushCopperMuted}" />
                    <Setter TargetName="Bubble" Property="CornerRadius" Value="12,4,12,12" />
                    <Setter TargetName="Avatar" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="Avatar" Property="Background" Value="#1E1610" />
                    <Setter TargetName="AvatarText" Property="Text" Value="You" />
                    <Setter TargetName="AvatarText" Property="Foreground" Value="{StaticResource BrushCopperSoft}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="DeskSuggestionTemplate" DataType="{x:Type models:SuggestedAction}">
            <Border Margin="0,0,0,8"
                    Padding="12"
                    Background="#0C1118"
                    BorderBrush="{StaticResource BrushBorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <DockPanel Margin="0,8,0,0" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding SourceAgent}"
                                   Foreground="{StaticResource BrushCopperSoft}"
                                   FontFamily="IBM Plex Mono"
                                   FontSize="10.5"
                                   VerticalAlignment="Center" />
                        <Border DockPanel.Dock="Right"
                                Style="{StaticResource AccentBadge}"
                                Margin="10,0,0,0">
                            <TextBlock Text="{Binding Priority}"
                                       FontSize="10.5"
                                       FontFamily="IBM Plex Mono"
                                       Foreground="{StaticResource BrushCopperSoft}" />
                        </Border>
                    </DockPanel>
                    <TextBlock Text="{Binding Rationale}"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource BrushMuted}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LinkedArea, StringFormat=Area: {0}}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource BrushMuted}"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <Button Content="Open In Inbox"
                            Margin="0,10,0,0"
                            FontSize="11.5"
                            Padding="10,6"
                            Command="{Binding DataContext.OpenSuggestionInInboxCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="InboxSuggestionCardTemplate" DataType="{x:Type models:SuggestedAction}">
            <Border x:Name="Card"
                    Padding="12"
                    Background="#0C1118"
                    BorderBrush="{StaticResource BrushBorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="10"
                    MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=ActualWidth}"
                    HorizontalAlignment="Stretch"
                    UseLayoutRounding="True"
                    SnapsToDevicePixels="True"
                    ClipToBounds="True">
                <StackPanel MinWidth="0">
                    <TextBlock Text="{Binding Title}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <DockPanel Margin="0,6,0,0" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding SourceAgent}"
                                   Foreground="{StaticResource BrushCopperSoft}"
                                   FontFamily="IBM Plex Mono"
                                   FontSize="10.5"
                                   VerticalAlignment="Center" />
                        <Border DockPanel.Dock="Right"
                                Style="{StaticResource AccentBadge}"
                                Margin="8,0,0,0">
                            <TextBlock Text="{Binding InboxBadgeText}"
                                       FontSize="10.5"
                                       FontFamily="IBM Plex Mono"
                                       Foreground="{StaticResource BrushCopperSoft}" />
                        </Border>
                    </DockPanel>
                    <TextBlock Text="{Binding InboxSummary}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource BrushMuted}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                    <Border Margin="0,8,0,0"
                            Padding="6,3"
                            Background="{StaticResource BrushSuccessSoft}"
                            BorderBrush="#2E7851"
                            BorderThickness="1"
                            CornerRadius="5"
                            HorizontalAlignment="Left"
                            Visibility="{Binding WasAutoStaged, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Auto-staged"
                                   FontSize="10"
                                   FontFamily="IBM Plex Mono"
                                   Foreground="#9FD0B2" />
                    </Border>
                </StackPanel>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                    <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource BrushCopper}" />
                    <Setter TargetName="Card" Property="Background" Value="#141B24" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- MAIN LAYOUT: Sidebar + Content                                     -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="64" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════ SIDEBAR ═══════ -->
        <Border Grid.Column="0"
                Background="{StaticResource BrushSidebar}"
                BorderBrush="{StaticResource BrushBorderSubtle}"
                BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <!-- Brand mark -->
                <Border DockPanel.Dock="Top"
                        Padding="0,18,0,14"
                        HorizontalAlignment="Center">
                    <TextBlock Text="&#x25C6;"
                               FontSize="22"
                               Foreground="{StaticResource BrushCopper}"
                               HorizontalAlignment="Center"
                               ToolTip="Daily Office" />
                </Border>

                <!-- Bottom: status dot -->
                <Border DockPanel.Dock="Bottom"
                        Padding="0,14"
                        HorizontalAlignment="Center">
                    <Ellipse Width="8" Height="8"
                             Fill="{StaticResource BrushSuccess}"
                             Opacity="0.7"
                             ToolTip="Connected" />
                </Border>

                <!-- Navigation -->
                <ListBox Style="{StaticResource SidebarNavListStyle}"
                         ItemContainerStyle="{StaticResource SidebarNavItemStyle}"
                         SelectedIndex="{Binding SelectedPrimaryTabIndex, Mode=TwoWay}"
                         Margin="0,4,0,0">
                    <ListBoxItem ToolTip="Office">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE80F;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Office"
                                       FontSize="9"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem ToolTip="Inbox">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE715;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Inbox"
                                       FontSize="9"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem ToolTip="Library">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE736;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Library"
                                       FontSize="9"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem ToolTip="Guide">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE82D;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Guide"
                                       FontSize="9"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ═══════ CONTENT AREA ═══════ -->
        <Grid Grid.Column="1" Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ─── HEADER ─── -->
            <Border Grid.Row="0"
                    Padding="20,12,20,12"
                    Background="{StaticResource BrushPanel}"
                    BorderBrush="{StaticResource BrushBorderSubtle}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding OfficeName}"
                                   FontSize="20"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding OfficeSubtitle}"
                                   Margin="0,3,0,0"
                                   Foreground="{StaticResource BrushMuted}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="Refresh" Command="{Binding RefreshContextCommand}" />
                        <Button Content="Daily Brief" Command="{Binding RunMorningPassCommand}" />
                        <Button Content="Suite" Command="{Binding RunSuiteCoachCommand}" />
                        <Button Content="&#xE8B7;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="14"
                                Padding="10,8"
                                ToolTip="Open Knowledge Folder"
                                Style="{StaticResource AccentButton}"
                                Command="{Binding OpenKnowledgeFolderCommand}" />
                        <Border Style="{StaticResource AccentBadge}"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding PendingApprovalBadge}"
                                       Foreground="{StaticResource BrushCopperSoft}"
                                       FontFamily="IBM Plex Mono"
                                       FontSize="11" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ─── ACTIVE JOB BANNER ─── -->
            <Border Grid.Row="1"
                    Padding="20,8"
                    Background="#0C1016"
                    BorderBrush="{StaticResource BrushCopperMuted}"
                    BorderThickness="0,0,0,1"
                    Visibility="{Binding HasActiveJob, Converter={StaticResource BoolToVis}}">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Left"
                            Style="{StaticResource AccentBadge}"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="Working"
                                   FontSize="10.5"
                                   FontFamily="IBM Plex Mono"
                                   Foreground="{StaticResource BrushCopperSoft}" />
                    </Border>
                    <ProgressBar DockPanel.Dock="Right"
                                 Width="120"
                                 Margin="12,0,0,0"
                                 VerticalAlignment="Center"
                                 IsIndeterminate="True" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding ActiveJobSummary}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding ActiveJobMeta}"
                                   Foreground="{StaticResource BrushMuted}"
                                   FontFamily="IBM Plex Mono"
                                   FontSize="10"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- MAIN TAB CONTENT                                           -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <TabControl Grid.Row="2"
                        Style="{StaticResource HeaderlessTabControlStyle}"
                        SelectedIndex="{Binding SelectedPrimaryTabIndex, Mode=TwoWay}">

            <!-- ╔═══════════════════════════════════════════════════════╗ -->
            <!-- ║ TAB 0: OFFICE                                         ║ -->
            <!-- ╚═══════════════════════════════════════════════════════╝ -->
            <TabItem>
                <Grid Margin="16,14,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" MinWidth="220" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="310" MinWidth="260" />
                    </Grid.ColumnDefinitions>

                    <!-- Agent Desk List -->
                    <Border Grid.Column="0" Style="{StaticResource Panel}">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="Direct Desks" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Suite-aware agent threads."
                                           Margin="0,4,0,12"
                                           Style="{StaticResource SectionSubtitleStyle}" />
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Agents}"
                                     SelectedItem="{Binding SelectedDesk, Mode=TwoWay}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:AgentCard}">
                                        <Border x:Name="Card"
                                                Padding="12"
                                                Background="#0C1118"
                                                BorderBrush="{StaticResource BrushBorderSubtle}"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Role}"
                                                               Margin="0,4,0,0"
                                                               Foreground="{StaticResource BrushMuted}"
                                                               FontSize="12"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        VerticalAlignment="Top"
                                                        Width="8" Height="8"
                                                        CornerRadius="4"
                                                        Margin="0,4,0,0"
                                                        Background="{Binding Accent}"
                                                        ToolTip="{Binding Status}" />
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                <Setter TargetName="Card" Property="BorderBrush" Value="{Binding Accent}" />
                                                <Setter TargetName="Card" Property="Background" Value="#141B24" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="True"
                                  Background="Transparent" />

                    <!-- Center: Desk Header + Thread + Input -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Desk Header -->
                        <Border Grid.Row="0"
                                Style="{StaticResource Panel}"
                                Margin="0,0,0,8"
                                Padding="16,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedDesk.Name, TargetNullValue=Select a desk}"
                                               FontSize="22"
                                               FontWeight="Bold" />
                                    <TextBlock Text="{Binding SelectedDesk.Role}"
                                               Margin="0,4,0,0"
                                               Foreground="{StaticResource BrushCopperSoft}"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding SelectedDeskSummary}"
                                               Margin="0,8,0,0"
                                               FontSize="12.5"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding SelectedDeskContextSummary}"
                                               Margin="0,4,0,0"
                                               Foreground="{StaticResource BrushMuted}"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Margin="14,0,0,0"
                                        VerticalAlignment="Top"
                                        Width="10" Height="10"
                                        CornerRadius="5"
                                        Background="{Binding SelectedDesk.Accent}"
                                        ToolTip="{Binding SelectedDesk.Status}" />
                            </Grid>
                        </Border>

                        <!-- Thread -->
                        <Border Grid.Row="1"
                                Style="{StaticResource Panel}"
                                Padding="16,12">
                            <DockPanel LastChildFill="True">
                                <StackPanel DockPanel.Dock="Top">
                                    <TextBlock Text="Desk Thread"
                                               Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding SelectedDeskThreadSummary}"
                                               Margin="0,3,0,10"
                                               Style="{StaticResource SectionSubtitleStyle}" />
                                </StackPanel>
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding DeskMessages}"
                                                  ItemTemplate="{StaticResource DeskMessageTemplate}" />
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <!-- Message Input -->
                        <Border Grid.Row="2"
                                Margin="0,8,0,0"
                                Padding="14,12"
                                Background="{StaticResource BrushPanel}"
                                BorderBrush="{StaticResource BrushBorderSubtle}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedDeskPromptHint}"
                                               Foreground="{StaticResource BrushMuted}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,8" />
                                    <TextBox MinHeight="80"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             Text="{Binding DeskMessageDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Margin="12,20,0,0"
                                        VerticalAlignment="Top"
                                        Style="{StaticResource AccentButton}"
                                        Content="Send &#x2192;"
                                        Command="{Binding SendDeskMessageCommand}" />
                            </Grid>
                        </Border>
                    </Grid>

                    <GridSplitter Grid.Column="3"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="True"
                                  Background="Transparent" />

                    <!-- Right Panel: Actions + Suggestions -->
                    <ScrollViewer Grid.Column="4"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Border Style="{StaticResource Panel}">
                                <StackPanel>
                                    <TextBlock Text="Desk Actions"
                                               Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="Quick desk operations."
                                               Margin="0,3,0,10"
                                               Style="{StaticResource SectionSubtitleStyle}" />
                                    <ItemsControl ItemsSource="{Binding DeskQuickActions}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:DeskAction}">
                                                <Button Content="{Binding Label}"
                                                        FontSize="11.5"
                                                        Padding="10,6"
                                                        Command="{Binding DataContext.RunDeskActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ItemsControl Margin="0,10,0,0"
                                                  ItemsSource="{Binding DeskPanels}"
                                                  ItemTemplate="{StaticResource FocusCardTemplate}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Panel}"
                                    Margin="0,8,0,0">
                                <DockPanel LastChildFill="True">
                                    <StackPanel DockPanel.Dock="Top">
                                        <TextBlock Text="Suggested Moves"
                                                   Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="{Binding SuggestionMemorySummary}"
                                                   Margin="0,3,0,10"
                                                   Style="{StaticResource SectionSubtitleStyle}" />
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding DeskSuggestions}"
                                                  ItemTemplate="{StaticResource DeskSuggestionTemplate}" />
                                </DockPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ╔═══════════════════════════════════════════════════════╗ -->
            <!-- ║ TAB 1: INBOX                                          ║ -->
            <!-- ╚═══════════════════════════════════════════════════════╝ -->
            <TabItem>
                <Grid Margin="16,14,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" MinWidth="280" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Inbox List -->
                    <Border Grid.Column="0" Style="{StaticResource Panel}">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="Work Inbox"
                                           Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Approvals, suggestions, and queued work."
                                           Margin="0,3,0,12"
                                           Style="{StaticResource SectionSubtitleStyle}" />
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          PanningMode="VerticalOnly">
                                <StackPanel Margin="0,0,4,20">
                                    <!-- Approvals -->
                                    <TextBlock Text="Approvals"
                                               Style="{StaticResource SectionTitleStyle}"
                                               FontSize="13" />
                                    <TextBlock Text="{Binding ApprovalInboxSummary}"
                                               Margin="0,3,0,8"
                                               Style="{StaticResource SectionSubtitleStyle}" />
                                    <ListBox ItemsSource="{Binding PendingApprovalSuggestions}"
                                             SelectedValuePath="Id"
                                             SelectedValue="{Binding SelectedInboxSuggestionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ItemTemplate="{StaticResource InboxSuggestionCardTemplate}" />

                                    <!-- Suggestions -->
                                    <TextBlock Text="Suggestions"
                                               Margin="0,12,0,0"
                                               Style="{StaticResource SectionTitleStyle}"
                                               FontSize="13" />
                                    <TextBlock Text="{Binding SuggestionsSummary}"
                                               Margin="0,3,0,8"
                                               Style="{StaticResource SectionSubtitleStyle}" />
                                    <ListBox ItemsSource="{Binding OpenSuggestions}"
                                             SelectedValuePath="Id"
                                             SelectedValue="{Binding SelectedInboxSuggestionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ItemTemplate="{StaticResource InboxSuggestionCardTemplate}" />

                                    <!-- Approved Next -->
                                    <TextBlock Text="Approved next"
                                               Margin="0,12,0,0"
                                               Style="{StaticResource SectionTitleStyle}"
                                               FontSize="13" />
                                    <TextBlock Text="{Binding ApprovedSuggestionsSummary}"
                                               Margin="0,3,0,8"
                                               Style="{StaticResource SectionSubtitleStyle}" />
                                    <ListBox ItemsSource="{Binding ApprovedSuggestions}"
                                             SelectedValuePath="Id"
                                             SelectedValue="{Binding SelectedInboxSuggestionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ItemTemplate="{StaticResource InboxSuggestionCardTemplate}" />

                                    <!-- Queued Work -->
                                    <TextBlock Text="Queued work"
                                               Margin="0,12,0,0"
                                               Style="{StaticResource SectionTitleStyle}"
                                               FontSize="13" />
                                    <TextBlock Text="{Binding QueuedWorkSummary}"
                                               Margin="0,3,0,8"
                                               Style="{StaticResource SectionSubtitleStyle}" />
                                    <ListBox ItemsSource="{Binding QueuedWorkSuggestions}"
                                             SelectedValuePath="Id"
                                             SelectedValue="{Binding SelectedInboxSuggestionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ItemTemplate="{StaticResource InboxSuggestionCardTemplate}" />
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="True"
                                  Background="Transparent" />

                    <!-- Inbox Detail -->
                    <Border Grid.Column="2" Style="{StaticResource Panel}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      PanningMode="VerticalOnly"
                                      PreviewMouseWheel="NestedScrollViewer_OnPreviewMouseWheel">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedInboxSuggestion.Title, TargetNullValue=Select a suggestion}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedInboxSuggestion.SourceAgent}"
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource BrushCopperSoft}"
                                           FontFamily="IBM Plex Mono"
                                           FontSize="10.5" />
                                <TextBlock Text="{Binding SelectedInboxLaneSummary}"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource BrushMuted}"
                                           FontSize="12"
                                           TextWrapping="Wrap" />

                                <!-- Auto-staged badge -->
                                <Border Margin="0,10,0,0"
                                        Padding="6,3"
                                        Background="{StaticResource BrushSuccessSoft}"
                                        BorderBrush="#2E7851"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        HorizontalAlignment="Left"
                                        Visibility="{Binding SelectedInboxSuggestion.WasAutoStaged, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Auto-staged from self-serve research"
                                               FontSize="10"
                                               FontFamily="IBM Plex Mono"
                                               Foreground="#9FD0B2" />
                                </Border>

                                <!-- Meta badges -->
                                <WrapPanel Margin="0,12,0,0">
                                    <Border Style="{StaticResource MetaBadge}" Margin="0,0,6,6">
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.Priority, StringFormat=Priority: {0}}"
                                                   FontSize="10.5"
                                                   Foreground="{StaticResource BrushTextSecondary}" />
                                    </Border>
                                    <Border Style="{StaticResource MetaBadge}" Margin="0,0,6,6">
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.ActionType, StringFormat=Type: {0}}"
                                                   FontSize="10.5"
                                                   Foreground="{StaticResource BrushTextSecondary}" />
                                    </Border>
                                    <Border Style="{StaticResource MetaBadge}" Margin="0,0,6,6">
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.LinkedArea, StringFormat=Area: {0}}"
                                                   FontSize="10.5"
                                                   Foreground="{StaticResource BrushTextSecondary}" />
                                    </Border>
                                </WrapPanel>

                                <!-- Rationale and detail fields -->
                                <Border Margin="0,14,0,0"
                                        Padding="14"
                                        Background="#0A0F16"
                                        CornerRadius="10"
                                        BorderBrush="{StaticResource BrushBorderSubtle}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.Rationale}"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   LineHeight="20" />
                                        <Border Margin="0,12,0,12"
                                                Height="1"
                                                Background="{StaticResource BrushBorderSubtle}" />
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.ExpectedBenefit, StringFormat=Expected benefit: {0}}"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.WhatYouLearn, StringFormat=What you learn: {0}}"
                                                   Margin="0,8,0,0"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.ProductImpact, StringFormat=Product impact: {0}}"
                                                   Margin="0,8,0,0"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.CareerValue, StringFormat=Career value: {0}}"
                                                   Margin="0,8,0,0"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <!-- Approval decision -->
                                <Border Margin="0,14,0,0"
                                        Padding="14"
                                        Background="#0E1118"
                                        CornerRadius="10"
                                        BorderBrush="{StaticResource BrushBorderSubtle}"
                                        BorderThickness="1"
                                        Visibility="{Binding ShowApprovalDecisionActions, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="Decision"
                                                   Style="{StaticResource SectionTitleStyle}"
                                                   Foreground="{StaticResource BrushCopperSoft}" />
                                        <TextBlock Text="Reason"
                                                   Margin="0,10,0,4"
                                                   FontSize="12"
                                                   Foreground="{StaticResource BrushTextSecondary}" />
                                        <TextBox Text="{Binding SelectedInboxSuggestion.OutcomeReasonInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Outcome note"
                                                   Margin="0,10,0,4"
                                                   FontSize="12"
                                                   Foreground="{StaticResource BrushTextSecondary}" />
                                        <TextBox MinHeight="80"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 Text="{Binding SelectedInboxSuggestion.OutcomeNoteInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Border>

                                <!-- Action buttons -->
                                <WrapPanel Margin="0,12,0,0">
                                    <Button Content="Approve only"
                                            Style="{StaticResource AccentButton}"
                                            Command="{Binding AcceptSuggestedActionCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowApprovalDecisionActions, Converter={StaticResource BoolToVis}}" />
                                    <Button Content="Approve &amp; queue"
                                            Style="{StaticResource AccentButton}"
                                            Command="{Binding ApproveAndQueueSuggestedActionCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowApproveAndQueueAction, Converter={StaticResource BoolToVis}}" />
                                    <Button Content="Approve &amp; run"
                                            Style="{StaticResource AccentButton}"
                                            Command="{Binding ApproveAndRunSuggestedActionCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowApproveAndRunAction, Converter={StaticResource BoolToVis}}" />
                                    <Button Content="Defer"
                                            Command="{Binding DeferSuggestedActionCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowApprovalDecisionActions, Converter={StaticResource BoolToVis}}" />
                                    <Button Content="Reject"
                                            Command="{Binding RejectSuggestedActionCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowApprovalDecisionActions, Converter={StaticResource BoolToVis}}" />
                                    <Button Content="Queue"
                                            Style="{StaticResource AccentButton}"
                                            Command="{Binding QueueSuggestedActionCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowSuggestionQueueActions, Converter={StaticResource BoolToVis}}" />
                                    <Button Content="Run now"
                                            Command="{Binding RunSuggestedActionNowCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowSuggestionQueueActions, Converter={StaticResource BoolToVis}}" />
                                    <Button Content="Dismiss"
                                            Command="{Binding DeferSuggestedActionCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowSuggestionQueueActions, Converter={StaticResource BoolToVis}}" />
                                    <Button Content="Queue"
                                            Style="{StaticResource AccentButton}"
                                            Command="{Binding QueueSuggestedActionCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowApprovedFollowThroughActions, Converter={StaticResource BoolToVis}}" />
                                    <Button Content="Run now"
                                            Command="{Binding RunSuggestedActionNowCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowApprovedFollowThroughActions, Converter={StaticResource BoolToVis}}" />
                                    <Button Content="Run now"
                                            Command="{Binding RunSuggestedActionNowCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowQueuedWorkActions, Converter={StaticResource BoolToVis}}" />
                                </WrapPanel>

                                <!-- Latest result -->
                                <Border Margin="0,16,0,0"
                                        Padding="14"
                                        Background="#0A0F16"
                                        BorderBrush="{StaticResource BrushBorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Visibility="{Binding SelectedInboxSuggestion.HasLatestResult, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="Latest result"
                                                   Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.LatestResultSummary}"
                                                   Margin="0,6,0,0"
                                                   FontSize="13"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.LatestResultDetail}"
                                                   Margin="0,8,0,0"
                                                   Foreground="{StaticResource BrushMuted}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                        <ItemsControl Margin="0,10,0,0"
                                                      ItemsSource="{Binding SelectedInboxSuggestion.LatestResultSources}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"
                                                               Margin="0,0,0,6"
                                                               Foreground="{StaticResource BrushCopperSoft}"
                                                               FontSize="12"
                                                               TextWrapping="Wrap" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Execution history -->
                                <Border Margin="0,12,0,0"
                                        Padding="14"
                                        Background="#0A0F16"
                                        BorderBrush="{StaticResource BrushBorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="Execution history"
                                                   Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="{Binding SuggestionExecutionHistorySummary}"
                                                   Margin="0,3,0,10"
                                                   Style="{StaticResource SectionSubtitleStyle}" />
                                        <ItemsControl ItemsSource="{Binding SuggestionExecutionHistory}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:OperatorActivityRecord}">
                                                    <Border Margin="0,0,0,8"
                                                            Padding="10"
                                                            Background="#0E141C"
                                                            BorderBrush="{StaticResource BrushBorderSubtle}"
                                                            BorderThickness="1"
                                                            CornerRadius="8">
                                                        <StackPanel>
                                                            <DockPanel LastChildFill="False">
                                                                <TextBlock DockPanel.Dock="Left"
                                                                           Text="{Binding DisplayEventLabel}"
                                                                           FontSize="12.5"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock DockPanel.Dock="Right"
                                                                           Text="{Binding DisplayMeta}"
                                                                           Foreground="{StaticResource BrushMuted}"
                                                                           FontSize="10"
                                                                           FontFamily="IBM Plex Mono" />
                                                            </DockPanel>
                                                            <TextBlock Text="{Binding Summary}"
                                                                       Margin="0,4,0,0"
                                                                       Foreground="{StaticResource BrushMuted}"
                                                                       FontSize="12"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ╔═══════════════════════════════════════════════════════╗ -->
            <!-- ║ TAB 2: LIBRARY                                        ║ -->
            <!-- ╚═══════════════════════════════════════════════════════╝ -->
            <TabItem>
                <Grid Margin="16,14,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Knowledge + Topics -->
                    <ScrollViewer Grid.Column="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Border Style="{StaticResource Panel}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Knowledge Library"
                                               Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding LearningLibrarySummary}"
                                               Margin="0,3,0,10"
                                               Style="{StaticResource SectionSubtitleStyle}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Button Content="Import files"
                                                FontSize="11.5"
                                                Padding="10,6"
                                                Margin="0,0,8,0"
                                                Command="{Binding ImportKnowledgeFilesCommand}" />
                                        <Button Content="Open folder"
                                                FontSize="11.5"
                                                Padding="10,6"
                                                Command="{Binding OpenKnowledgeFolderCommand}" />
                                    </StackPanel>
                                    <TextBlock Text="Sources"
                                               Margin="0,0,0,6"
                                               Foreground="{StaticResource BrushCopperSoft}"
                                               FontFamily="IBM Plex Mono"
                                               FontSize="10" />
                                    <ItemsControl ItemsSource="{Binding KnowledgeSourceSummaries}"
                                                  Margin="0,0,0,10">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Margin="0,0,0,6"
                                                           Foreground="{StaticResource BrushMuted}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ItemsControl ItemsSource="{Binding ImportedDocumentSummaries}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Panel}">
                                <StackPanel>
                                    <TextBlock Text="Learning Topics"
                                               Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding LearningProfileSummary}"
                                               Margin="0,3,0,10"
                                               Style="{StaticResource SectionSubtitleStyle}" />
                                    <ItemsControl ItemsSource="{Binding LearningTopicSummaries}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <GridSplitter Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="True"
                                  Background="Transparent" />

                    <!-- Right: Training + Research -->
                    <ScrollViewer Grid.Column="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Border Style="{StaticResource Panel}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Training Memory"
                                               Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding TrainingOverallSummary}"
                                               Margin="0,3,0,10"
                                               Style="{StaticResource SectionSubtitleStyle}" />
                                    <TextBlock Text="{Binding TrainingSession.HistorySummary}"
                                               Foreground="{StaticResource BrushCopperSoft}"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding TrainingSession.ChecklistSummary}"
                                               Margin="0,8,0,0"
                                               Foreground="{StaticResource BrushMuted}"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                    <ItemsControl Margin="0,10,0,0"
                                                  ItemsSource="{Binding RecentPracticeSummaries}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Panel}">
                                <StackPanel>
                                    <TextBlock Text="Recent Research"
                                               Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding ResearchSummary}"
                                               Margin="0,3,0,10"
                                               Style="{StaticResource SectionSubtitleStyle}" />
                                    <ItemsControl ItemsSource="{Binding ResearchSources}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:ResearchSource}">
                                                <TextBlock Margin="0,0,0,6"
                                                           FontSize="12"
                                                           TextWrapping="Wrap">
                                                    <Run Text="{Binding Title}" />
                                                    <Run Text=" | " Foreground="{StaticResource BrushMuted}" />
                                                    <Run Text="{Binding SourceLabel}" Foreground="{StaticResource BrushCopperSoft}" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ╔═══════════════════════════════════════════════════════╗ -->
            <!-- ║ TAB 3: GUIDE                                          ║ -->
            <!-- ╚═══════════════════════════════════════════════════════╝ -->
            <TabItem>
                <Grid Margin="16,14,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Guide header -->
                    <Border Grid.Row="0"
                            Style="{StaticResource Panel}"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{Binding AgentReplyGuideTitle}"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Foreground="{StaticResource BrushCopperSoft}" />
                            <TextBlock Text="{Binding AgentReplyGuideSummary}"
                                       Margin="0,4,0,8"
                                       Style="{StaticResource SectionSubtitleStyle}" />
                            <TextBlock Text="{Binding AgentReplyGuidePathSummary}"
                                       Foreground="{StaticResource BrushCopperSoft}"
                                       FontFamily="IBM Plex Mono"
                                       FontSize="10.5"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Guide content -->
                    <Border Grid.Row="1" Style="{StaticResource Panel}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding AgentReplyGuideSections}"
                                          ItemTemplate="{StaticResource GuideSectionTemplate}" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
            </TabControl>

            <!-- ─── STATUS BAR ─── -->
            <Border Grid.Row="3"
                    Padding="20,6"
                    Background="{StaticResource BrushSidebar}"
                    BorderBrush="{StaticResource BrushBorderSubtle}"
                    BorderThickness="0,1,0,0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Left"
                               Text="{Binding StatusMessage, TargetNullValue=Ready}"
                               Foreground="{StaticResource BrushMuted}"
                               FontSize="10.5"
                               FontFamily="IBM Plex Mono"
                               VerticalAlignment="Center" />
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding InstalledModelSummary}"
                               Foreground="{StaticResource BrushMuted}"
                               FontSize="10.5"
                               FontFamily="IBM Plex Mono"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right" />
                    <Border />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
