<Window x:Class="DailyDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:DailyDesk.Models;assembly=DailyDesk.Core"
        Title="Office"
        Icon="Assets/office.ico"
        Width="1680"
        Height="990"
        MinWidth="1400"
        MinHeight="860"
        Background="{StaticResource BrushWindow}"
        FontFamily="Plus Jakarta Sans"
        Foreground="{StaticResource BrushText}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <ControlTemplate x:Key="ButtonChromeTemplate" TargetType="Button">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="10"
                    SnapsToDevicePixels="True">
                <ContentPresenter Margin="{TemplateBinding Padding}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  RecognizesAccessKey="True" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource BrushCopper}" />
                    <Setter TargetName="Chrome" Property="Background" Value="#1C2430" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Chrome" Property="Background" Value="#241A10" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Chrome" Property="Opacity" Value="0.52" />
                    <Setter TargetName="Chrome" Property="Background" Value="#121821" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Width="{TemplateBinding Width}"
                  Background="Transparent"
                  Margin="2,0,0,0">
                <Border Margin="3,2,1,2"
                        Background="#0C1117"
                        BorderBrush="#172231"
                        BorderThickness="1"
                        CornerRadius="999"
                        Opacity="0.92" />
                <Track x:Name="PART_Track"
                       IsDirectionReversed="True"
                       Focusable="False"
                       Margin="3,2,1,2">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.LineUpCommand"
                                      Focusable="False"
                                      Opacity="0"
                                      IsTabStop="False" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.LineDownCommand"
                                      Focusable="False"
                                      Opacity="0"
                                      IsTabStop="False" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Height="{TemplateBinding Height}"
                  Background="Transparent"
                  Margin="0,2,0,0">
                <Border Margin="2,3,2,1"
                        Background="#0C1117"
                        BorderBrush="#172231"
                        BorderThickness="1"
                        CornerRadius="999"
                        Opacity="0.92" />
                <Track x:Name="PART_Track"
                       Focusable="False"
                       Margin="2,3,2,1">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.LineLeftCommand"
                                      Focusable="False"
                                      Opacity="0"
                                      IsTabStop="False" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="ScrollBar.LineRightCommand"
                                      Focusable="False"
                                      Opacity="0"
                                      IsTabStop="False" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource BrushText}" />
            <Setter Property="Background" Value="{StaticResource BrushPanelRaised}" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template" Value="{StaticResource ButtonChromeTemplate}" />
        </Style>

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushPanel}" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="RaisedPanel" TargetType="Border" BasedOn="{StaticResource Panel}">
            <Setter Property="Background" Value="{StaticResource BrushPanelRaised}" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0D1218" />
            <Setter Property="Foreground" Value="{StaticResource BrushText}" />
            <Setter Property="BorderBrush" Value="#324763" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="CaretBrush" Value="{StaticResource BrushCopper}" />
            <Setter Property="SelectionBrush" Value="{StaticResource BrushSignalBlue}" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="MinWidth" Value="22" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbChrome"
                                Margin="1"
                                BorderThickness="1"
                                CornerRadius="999"
                                BorderBrush="#6F86A4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6F86A4" Offset="0" />
                                    <GradientStop Color="#41566E" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="#92A8C3" />
                                <Setter TargetName="ThumbChrome" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#8CA4C1" Offset="0" />
                                            <GradientStop Color="#536D87" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#C7A05C" Offset="0" />
                                            <GradientStop Color="#7E6440" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="{StaticResource BrushCopper}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource BrushCopper}" />
            <Setter Property="Background" Value="#1C2430" />
            <Setter Property="Height" Value="8" />
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}" />
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Margin="0,0,0,12"
                                    Padding="8,6"
                                    Background="#0D1218"
                                    BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    ClipToBounds="False"
                                    SnapsToDevicePixels="True">
                                <TabPanel Background="Transparent"
                                          ClipToBounds="False"
                                          SnapsToDevicePixels="True"
                                          IsItemsHost="True" />
                            </Border>
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
            <Setter Property="Background" Value="#0D131A" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="66" />
            <Setter Property="Panel.ZIndex" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="#1A2230" />
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="{StaticResource BrushCopper}" />
                                <Setter Property="Foreground" Value="{StaticResource BrushText}" />
                                <Setter Property="Panel.ZIndex" Value="10" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="#18202C" />
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="#3A4D61" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TabChrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderlessTabControlStyle" TargetType="TabControl">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <ContentPresenter ContentSource="SelectedContent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionNavListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionNavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource BrushMuted}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="NavChrome"
                                Padding="16,8"
                                Background="#0D131A"
                                BorderBrush="{StaticResource BrushBorder}"
                                BorderThickness="1"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="NavChrome" Property="Background" Value="#1A2230" />
                                <Setter TargetName="NavChrome" Property="BorderBrush" Value="{StaticResource BrushCopper}" />
                                <Setter Property="Foreground" Value="{StaticResource BrushText}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavChrome" Property="Background" Value="#18202C" />
                                <Setter TargetName="NavChrome" Property="BorderBrush" Value="#3A4D61" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="NavChrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <DataTemplate x:Key="GuideSectionBlockTemplate" DataType="{x:Type models:GuideSectionBlock}">
            <Border Margin="{Binding Margin}"
                    Padding="{Binding Padding}"
                    Background="{Binding Background}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="{Binding BorderThickness}"
                    CornerRadius="{Binding CornerRadius}">
                <TextBlock Text="{Binding Text}"
                           Foreground="{Binding Foreground}"
                           FontFamily="{Binding FontFamily}"
                           FontSize="{Binding FontSize}"
                           FontWeight="{Binding FontWeight}"
                           TextWrapping="Wrap" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="GuideSectionTemplate" DataType="{x:Type models:GuideSection}">
            <Border Margin="0,0,0,14"
                    Padding="16"
                    Background="{Binding BackgroundBrush}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{Binding AccentBrush}"
                               TextWrapping="Wrap" />
                    <Border Margin="0,10,0,12"
                            Height="2"
                            Width="72"
                            HorizontalAlignment="Left"
                            Background="{Binding AccentBrush}"
                            CornerRadius="999" />
                    <ItemsControl ItemsSource="{Binding Blocks}"
                                  ItemTemplate="{StaticResource GuideSectionBlockTemplate}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="FocusCardTemplate" DataType="{x:Type models:FocusCard}">
            <Border Margin="0,0,0,12"
                    Padding="14"
                    Background="#0D1218"
                    BorderBrush="{Binding Accent}"
                    BorderThickness="1"
                    CornerRadius="14">
                <StackPanel>
                    <TextBlock Text="{Binding Tag}"
                               Foreground="{Binding Accent}"
                               FontSize="11"
                               FontFamily="IBM Plex Mono" />
                    <TextBlock Text="{Binding Title}"
                               Margin="0,8,0,0"
                               FontSize="16"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Summary}"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource BrushMuted}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DeskMessageTemplate" DataType="{x:Type models:DeskMessageRecord}">
            <Border x:Name="Bubble"
                    Margin="0,0,0,12"
                    Padding="14"
                    Background="#0F141B"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="16"
                    MaxWidth="680"
                    HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="{Binding Meta}"
                               Foreground="{StaticResource BrushMuted}"
                               FontSize="11"
                               FontFamily="IBM Plex Mono" />
                    <TextBlock Text="{Binding Content}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsUser}" Value="True">
                    <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right" />
                    <Setter TargetName="Bubble" Property="Background" Value="#241A10" />
                    <Setter TargetName="Bubble" Property="BorderBrush" Value="{StaticResource BrushCopper}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="DeskSuggestionTemplate" DataType="{x:Type models:SuggestedAction}">
            <Border Margin="0,0,0,12"
                    Padding="14"
                    Background="#0D1218"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="14">
                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <DockPanel Margin="0,8,0,0"
                               LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding SourceAgent}"
                                   Foreground="{StaticResource BrushCopperSoft}"
                                   FontFamily="IBM Plex Mono"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                        <Border DockPanel.Dock="Right"
                                Padding="8,4"
                                Margin="12,0,0,0"
                                Background="#171E28"
                                BorderBrush="{StaticResource BrushCopper}"
                                BorderThickness="1"
                                CornerRadius="999"
                                HorizontalAlignment="Right">
                            <TextBlock Text="{Binding Priority}"
                                       FontSize="11"
                                       FontFamily="IBM Plex Mono"
                                       Foreground="{StaticResource BrushCopperSoft}" />
                        </Border>
                    </DockPanel>
                    <TextBlock Text="{Binding Rationale}"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource BrushMuted}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LinkedArea, StringFormat=Area: {0}}"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource BrushMuted}"
                               TextWrapping="Wrap" />
                    <Button Content="Open In Inbox"
                            Margin="0,12,0,0"
                            Command="{Binding DataContext.OpenSuggestionInInboxCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="InboxSuggestionCardTemplate" DataType="{x:Type models:SuggestedAction}">
            <Border x:Name="Card"
                    Padding="14"
                    Background="#0D1218"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="16"
                    MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=ActualWidth}"
                    HorizontalAlignment="Stretch"
                    UseLayoutRounding="True"
                    SnapsToDevicePixels="True"
                    ClipToBounds="True">
                <StackPanel MinWidth="0">
                    <TextBlock Text="{Binding Title}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <DockPanel Margin="0,8,0,0"
                               LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding SourceAgent}"
                                   Foreground="{StaticResource BrushCopperSoft}"
                                   FontFamily="IBM Plex Mono"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                        <Border DockPanel.Dock="Right"
                                Padding="8,4"
                                Margin="10,0,0,0"
                                Background="#171E28"
                                BorderBrush="{StaticResource BrushCopper}"
                                BorderThickness="1"
                                CornerRadius="999"
                                HorizontalAlignment="Right">
                            <TextBlock Text="{Binding InboxBadgeText}"
                                       FontSize="11"
                                       FontFamily="IBM Plex Mono"
                                       Foreground="{StaticResource BrushCopperSoft}" />
                        </Border>
                    </DockPanel>
                    <TextBlock Text="{Binding InboxSummary}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource BrushMuted}"
                               TextWrapping="Wrap" />
                    <Border Margin="0,10,0,0"
                            Padding="8,4"
                            Background="#14211A"
                            BorderBrush="#2E7851"
                            BorderThickness="1"
                            CornerRadius="999"
                            HorizontalAlignment="Left"
                            Visibility="{Binding WasAutoStaged, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Auto-staged"
                                   FontSize="11"
                                   FontFamily="IBM Plex Mono"
                                   Foreground="#9FD0B2" />
                    </Border>
                </StackPanel>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                    <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource BrushCopper}" />
                    <Setter TargetName="Card" Property="Background" Value="#171F29" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource Panel}"
                Margin="0,0,0,16"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding OfficeName}" FontSize="36" FontWeight="Bold" />
                    <TextBlock Text="{Binding OfficeSubtitle}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource BrushMuted}"
                               TextWrapping="Wrap" />
                    <Border Margin="0,14,0,0"
                            Padding="12"
                            Background="#0D1218"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Visibility="{Binding HasActiveJob, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <WrapPanel>
                                <Border Padding="8,4"
                                        Margin="0,0,10,8"
                                        Background="#241A10"
                                        BorderBrush="{StaticResource BrushCopper}"
                                        BorderThickness="1"
                                        CornerRadius="999">
                                    <TextBlock Text="Working"
                                               FontSize="11"
                                               FontFamily="IBM Plex Mono"
                                               Foreground="{StaticResource BrushCopperSoft}" />
                                </Border>
                                <TextBlock Text="{Binding ActiveJobSummary}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </WrapPanel>
                            <TextBlock Text="{Binding ActiveJobMeta}"
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource BrushMuted}"
                                       FontFamily="IBM Plex Mono"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                            <ProgressBar Margin="0,10,0,0"
                                         IsIndeterminate="True" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <WrapPanel HorizontalAlignment="Right">
                        <Button Content="Refresh Office" Command="{Binding RefreshContextCommand}" />
                        <Button Content="Daily Brief" Command="{Binding RunMorningPassCommand}" />
                        <Button Content="Suite Context" Command="{Binding RunSuiteCoachCommand}" />
                        <Button Content="Open Knowledge"
                                Background="#241A10"
                                BorderBrush="{StaticResource BrushCopper}"
                                Command="{Binding OpenKnowledgeFolderCommand}" />
                    </WrapPanel>
                    <Border HorizontalAlignment="Right"
                            Padding="12,7"
                            Background="#0D1218"
                            BorderBrush="{StaticResource BrushCopper}"
                            BorderThickness="1"
                            CornerRadius="999">
                        <TextBlock Text="{Binding PendingApprovalBadge}"
                                   Foreground="{StaticResource BrushCopperSoft}"
                                   FontFamily="IBM Plex Mono"
                                   FontSize="12" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,12"
                    Padding="8,6"
                    Background="#0D1218"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="14">
                <ListBox Style="{StaticResource SectionNavListStyle}"
                         ItemContainerStyle="{StaticResource SectionNavItemStyle}"
                         SelectedIndex="{Binding SelectedPrimaryTabIndex, Mode=TwoWay}">
                    <ListBoxItem Content="Office" />
                    <ListBoxItem Content="Inbox" />
                    <ListBoxItem Content="Library" />
                    <ListBoxItem Content="Guide" />
                </ListBox>
            </Border>

            <TabControl Grid.Row="1"
                        Style="{StaticResource HeaderlessTabControlStyle}"
                        SelectedIndex="{Binding SelectedPrimaryTabIndex, Mode=TwoWay}">
            <TabItem Header="Office">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="272" MinWidth="232" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Panel}">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="Direct Desks" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Suite-aware direct desks for engineering, CAD workflow, and business operations."
                                           Margin="0,6,0,14"
                                           Foreground="{StaticResource BrushMuted}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Agents}"
                                     SelectedItem="{Binding SelectedDesk, Mode=TwoWay}"
                                     Margin="0,0,4,0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:AgentCard}">
                                        <Border x:Name="Card"
                                                Padding="14"
                                                Background="#0D1218"
                                                BorderBrush="{StaticResource BrushBorder}"
                                                BorderThickness="1"
                                                CornerRadius="16"
                                                TextElement.Foreground="{StaticResource BrushText}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource BrushText}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Role}"
                                                               Margin="0,8,0,0"
                                                               Foreground="{StaticResource BrushMuted}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        Padding="8,4"
                                                        VerticalAlignment="Top"
                                                        Background="#171E28"
                                                        BorderBrush="{Binding Accent}"
                                                        BorderThickness="1"
                                                        CornerRadius="999">
                                                    <TextBlock Text="{Binding Status}"
                                                               FontSize="11"
                                                               FontFamily="IBM Plex Mono"
                                                               Foreground="{Binding Accent}" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                <Setter TargetName="Card" Property="BorderBrush" Value="{Binding Accent}" />
                                                <Setter TargetName="Card" Property="Background" Value="#171F29" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="True"
                                  Background="#1A2230" />

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource Panel}"
                                Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedDesk.Name, TargetNullValue=Choose a desk}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding SelectedDesk.Role}"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource BrushCopperSoft}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding SelectedDeskSummary}"
                                               Margin="0,12,0,0"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding SelectedDeskContextSummary}"
                                               Margin="0,8,0,0"
                                               Foreground="{StaticResource BrushMuted}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Margin="18,0,0,0"
                                        Padding="10,6"
                                        VerticalAlignment="Top"
                                        Background="#121924"
                                        BorderBrush="{Binding SelectedDesk.Accent}"
                                        BorderThickness="1"
                                        CornerRadius="999">
                                    <TextBlock Text="{Binding SelectedDesk.Status}"
                                               FontSize="11"
                                               FontFamily="IBM Plex Mono"
                                               Foreground="{Binding SelectedDesk.Accent}" />
                                </Border>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.6*" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="1.05*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource Panel}">
                                <DockPanel LastChildFill="True">
                                    <StackPanel DockPanel.Dock="Top">
                                        <TextBlock Text="Desk Thread" Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="{Binding SelectedDeskThreadSummary}"
                                                   Margin="0,6,0,12"
                                                   Foreground="{StaticResource BrushMuted}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding DeskMessages}"
                                                      ItemTemplate="{StaticResource DeskMessageTemplate}" />
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>

                            <GridSplitter Grid.Column="1"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          ResizeDirection="Columns"
                                          ResizeBehavior="PreviousAndNext"
                                          ShowsPreview="True"
                                          Background="#1A2230" />

                            <ScrollViewer Grid.Column="2"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="0,0,4,0">
                                    <Border Style="{StaticResource Panel}">
                                        <StackPanel>
                                            <TextBlock Text="Desk Actions" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Text="Run the desk directly, then keep the thread focused on real work."
                                                       Margin="0,6,0,12"
                                                       Foreground="{StaticResource BrushMuted}"
                                                       TextWrapping="Wrap" />
                                            <ItemsControl ItemsSource="{Binding DeskQuickActions}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type models:DeskAction}">
                                                        <Button Content="{Binding Label}"
                                                                Command="{Binding DataContext.RunDeskActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <ItemsControl Margin="0,12,0,0"
                                                          ItemsSource="{Binding DeskPanels}"
                                                          ItemTemplate="{StaticResource FocusCardTemplate}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource Panel}"
                                            Margin="0,14,0,0">
                                        <DockPanel LastChildFill="True">
                                            <StackPanel DockPanel.Dock="Top">
                                                <TextBlock Text="Suggested Moves" Style="{StaticResource SectionTitleStyle}" />
                                                <TextBlock Text="Only actionable, non-repo desk moves appear here."
                                                           Margin="0,6,0,4"
                                                           Foreground="{StaticResource BrushMuted}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding SuggestionMemorySummary}"
                                                           Margin="0,0,0,12"
                                                           Foreground="{StaticResource BrushMuted}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{Binding DeskSuggestions}"
                                                          ItemTemplate="{StaticResource DeskSuggestionTemplate}" />
                                        </DockPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <Border Grid.Row="2"
                                Style="{StaticResource Panel}"
                                Margin="0,14,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedDeskPromptHint}"
                                               Foreground="{StaticResource BrushMuted}"
                                               TextWrapping="Wrap" />
                                    <TextBox Margin="0,12,0,0"
                                             MinHeight="120"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             Text="{Binding DeskMessageDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Margin="16,34,0,0"
                                        VerticalAlignment="Top"
                                        Background="#241A10"
                                        BorderBrush="{StaticResource BrushCopper}"
                                        Content="Send To Desk"
                                        Command="{Binding SendDeskMessageCommand}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Inbox">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" MinWidth="300" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Panel}">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="Work Inbox" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="Approvals stay separate from self-serve suggestions and queued follow-through."
                                           Margin="0,6,0,14"
                                           Foreground="{StaticResource BrushMuted}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Visible"
                                          HorizontalScrollBarVisibility="Disabled"
                                          PanningMode="VerticalOnly">
                                <StackPanel Margin="0,0,10,28">
                                    <StackPanel>
                                        <TextBlock Text="Approvals"
                                                   Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="{Binding ApprovalInboxSummary}"
                                                   Margin="0,6,0,12"
                                                   Foreground="{StaticResource BrushMuted}"
                                                   TextWrapping="Wrap" />
                                        <ListBox ItemsSource="{Binding PendingApprovalSuggestions}"
                                                 SelectedValuePath="Id"
                                                 SelectedValue="{Binding SelectedInboxSuggestionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ItemTemplate="{StaticResource InboxSuggestionCardTemplate}" />
                                    </StackPanel>

                                    <StackPanel Margin="0,12,0,0">
                                        <TextBlock Text="Suggestions"
                                                   Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="{Binding SuggestionsSummary}"
                                                   Margin="0,6,0,12"
                                                   Foreground="{StaticResource BrushMuted}"
                                                   TextWrapping="Wrap" />
                                        <ListBox ItemsSource="{Binding OpenSuggestions}"
                                                 SelectedValuePath="Id"
                                                 SelectedValue="{Binding SelectedInboxSuggestionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ItemTemplate="{StaticResource InboxSuggestionCardTemplate}" />
                                    </StackPanel>

                                    <StackPanel Margin="0,12,0,0">
                                        <TextBlock Text="Approved next"
                                                   Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="{Binding ApprovedSuggestionsSummary}"
                                                   Margin="0,6,0,12"
                                                   Foreground="{StaticResource BrushMuted}"
                                                   TextWrapping="Wrap" />
                                        <ListBox ItemsSource="{Binding ApprovedSuggestions}"
                                                 SelectedValuePath="Id"
                                                 SelectedValue="{Binding SelectedInboxSuggestionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ItemTemplate="{StaticResource InboxSuggestionCardTemplate}" />
                                    </StackPanel>

                                    <StackPanel Margin="0,12,0,0">
                                        <TextBlock Text="Queued work"
                                                   Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="{Binding QueuedWorkSummary}"
                                                   Margin="0,6,0,12"
                                                   Foreground="{StaticResource BrushMuted}"
                                                   TextWrapping="Wrap" />
                                        <ListBox ItemsSource="{Binding QueuedWorkSuggestions}"
                                                 SelectedValuePath="Id"
                                                 SelectedValue="{Binding SelectedInboxSuggestionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ItemTemplate="{StaticResource InboxSuggestionCardTemplate}" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="True"
                                  Background="#1A2230" />

                    <Border Grid.Column="2" Style="{StaticResource Panel}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      PanningMode="VerticalOnly"
                                      PreviewMouseWheel="NestedScrollViewer_OnPreviewMouseWheel">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedInboxSuggestion.Title, TargetNullValue=Select a suggestion}"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedInboxSuggestion.SourceAgent}"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource BrushCopperSoft}"
                                           FontFamily="IBM Plex Mono"
                                           FontSize="11" />
                                <TextBlock Text="{Binding SelectedInboxLaneSummary}"
                                           Margin="0,10,0,0"
                                           Foreground="{StaticResource BrushMuted}"
                                           TextWrapping="Wrap" />
                                <Border Margin="0,12,0,0"
                                        Padding="8,4"
                                        Background="#14211A"
                                        BorderBrush="#2E7851"
                                        BorderThickness="1"
                                        CornerRadius="999"
                                        HorizontalAlignment="Left"
                                        Visibility="{Binding SelectedInboxSuggestion.WasAutoStaged, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Auto-staged from self-serve research"
                                               FontSize="11"
                                               FontFamily="IBM Plex Mono"
                                               Foreground="#9FD0B2" />
                                </Border>

                                <WrapPanel Margin="0,14,0,0">
                                    <Border Padding="10,6"
                                            Margin="0,0,10,10"
                                            Background="#121924"
                                            BorderBrush="{StaticResource BrushBorder}"
                                            BorderThickness="1"
                                            CornerRadius="999">
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.Priority, StringFormat=Priority: {0}}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource BrushMuted}" />
                                    </Border>
                                    <Border Padding="10,6"
                                            Margin="0,0,10,10"
                                            Background="#121924"
                                            BorderBrush="{StaticResource BrushBorder}"
                                            BorderThickness="1"
                                            CornerRadius="999">
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.ActionType, StringFormat=Type: {0}}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource BrushMuted}" />
                                    </Border>
                                    <Border Padding="10,6"
                                            Margin="0,0,10,10"
                                            Background="#121924"
                                            BorderBrush="{StaticResource BrushBorder}"
                                            BorderThickness="1"
                                            CornerRadius="999">
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.LinkedArea, StringFormat=Area: {0}}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource BrushMuted}" />
                                    </Border>
                                </WrapPanel>

                                <TextBlock Text="{Binding SelectedInboxSuggestion.Rationale}"
                                           Margin="0,14,0,0"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedInboxSuggestion.ExpectedBenefit, StringFormat=Expected benefit: {0}}"
                                           Margin="0,14,0,0"
                                           Foreground="{StaticResource BrushMuted}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedInboxSuggestion.WhatYouLearn, StringFormat=What you learn: {0}}"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource BrushMuted}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedInboxSuggestion.ProductImpact, StringFormat=Product impact: {0}}"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource BrushMuted}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedInboxSuggestion.CareerValue, StringFormat=Career value: {0}}"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource BrushMuted}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="Reason"
                                           Margin="0,18,0,6"
                                           Foreground="{StaticResource BrushCopperSoft}"
                                           Visibility="{Binding ShowApprovalDecisionActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <TextBlock Text="Required before you approve, defer, or reject this suggestion."
                                           Margin="0,0,0,8"
                                           Foreground="{StaticResource BrushMuted}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding ShowApprovalDecisionActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <TextBox Text="{Binding SelectedInboxSuggestion.OutcomeReasonInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Visibility="{Binding ShowApprovalDecisionActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <TextBlock Text="Outcome note"
                                           Margin="0,14,0,6"
                                           Foreground="{StaticResource BrushCopperSoft}"
                                           Visibility="{Binding ShowApprovalDecisionActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <TextBox MinHeight="100"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Text="{Binding SelectedInboxSuggestion.OutcomeNoteInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Visibility="{Binding ShowApprovalDecisionActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <WrapPanel Margin="0,14,0,0">
                                    <Button Content="Approve only"
                                            Background="#241A10"
                                            BorderBrush="{StaticResource BrushCopper}"
                                            Command="{Binding AcceptSuggestedActionCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowApprovalDecisionActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Button Content="Approve &amp; queue"
                                            Background="#241A10"
                                            BorderBrush="{StaticResource BrushCopper}"
                                            Command="{Binding ApproveAndQueueSuggestedActionCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowApproveAndQueueAction, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Button Content="Approve &amp; run"
                                            Background="#241A10"
                                            BorderBrush="{StaticResource BrushCopper}"
                                            Command="{Binding ApproveAndRunSuggestedActionCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowApproveAndRunAction, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Button Content="Defer"
                                            Command="{Binding DeferSuggestedActionCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowApprovalDecisionActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Button Content="Reject"
                                            Command="{Binding RejectSuggestedActionCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowApprovalDecisionActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Button Content="Queue"
                                            Background="#241A10"
                                            BorderBrush="{StaticResource BrushCopper}"
                                            Command="{Binding QueueSuggestedActionCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowSuggestionQueueActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Button Content="Run now"
                                            Command="{Binding RunSuggestedActionNowCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowSuggestionQueueActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Button Content="Dismiss"
                                            Command="{Binding DeferSuggestedActionCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowSuggestionQueueActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Button Content="Queue"
                                            Background="#241A10"
                                            BorderBrush="{StaticResource BrushCopper}"
                                            Command="{Binding QueueSuggestedActionCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowApprovedFollowThroughActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Button Content="Run now"
                                            Command="{Binding RunSuggestedActionNowCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowApprovedFollowThroughActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Button Content="Run now"
                                            Command="{Binding RunSuggestedActionNowCommand}"
                                            CommandParameter="{Binding SelectedInboxSuggestion}"
                                            Visibility="{Binding ShowQueuedWorkActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </WrapPanel>
                                <Border Margin="0,20,0,0"
                                        Padding="14"
                                        Background="#0D1218"
                                        BorderBrush="{StaticResource BrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Visibility="{Binding SelectedInboxSuggestion.HasLatestResult, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="Latest result"
                                                   Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.LatestResultSummary}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedInboxSuggestion.LatestResultDetail}"
                                                   Margin="0,10,0,0"
                                                   Foreground="{StaticResource BrushMuted}"
                                                   TextWrapping="Wrap" />
                                        <ItemsControl Margin="0,12,0,0"
                                                      ItemsSource="{Binding SelectedInboxSuggestion.LatestResultSources}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"
                                                               Margin="0,0,0,8"
                                                               Foreground="{StaticResource BrushCopperSoft}"
                                                               TextWrapping="Wrap" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,20,0,0"
                                        Padding="14"
                                        Background="#0D1218"
                                        BorderBrush="{StaticResource BrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <TextBlock Text="Execution history"
                                                   Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="{Binding SuggestionExecutionHistorySummary}"
                                                   Margin="0,6,0,12"
                                                   Foreground="{StaticResource BrushMuted}"
                                                   TextWrapping="Wrap" />
                                        <ItemsControl ItemsSource="{Binding SuggestionExecutionHistory}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:OperatorActivityRecord}">
                                                    <Border Margin="0,0,0,10"
                                                            Padding="12"
                                                            Background="#121924"
                                                            BorderBrush="{StaticResource BrushBorder}"
                                                            BorderThickness="1"
                                                            CornerRadius="12">
                                                        <StackPanel>
                                                            <DockPanel LastChildFill="False">
                                                                <TextBlock DockPanel.Dock="Left"
                                                                           Text="{Binding DisplayEventLabel}"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock DockPanel.Dock="Right"
                                                                           Text="{Binding DisplayMeta}"
                                                                           Foreground="{StaticResource BrushMuted}"
                                                                           FontSize="11"
                                                                           FontFamily="IBM Plex Mono" />
                                                            </DockPanel>
                                                            <TextBlock Text="{Binding Summary}"
                                                                       Margin="0,6,0,0"
                                                                       Foreground="{StaticResource BrushMuted}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Library">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Border Style="{StaticResource Panel}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Knowledge Library" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding LearningLibrarySummary}"
                                               Margin="0,6,0,12"
                                               Foreground="{StaticResource BrushMuted}"
                                               TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Button Content="Import files"
                                                Margin="0,0,10,0"
                                                Command="{Binding ImportKnowledgeFilesCommand}" />
                                        <Button Content="Open folder"
                                                Command="{Binding OpenKnowledgeFolderCommand}" />
                                    </StackPanel>
                                    <TextBlock Text="Knowledge sources"
                                               Margin="0,0,0,8"
                                               Foreground="{StaticResource BrushCopperSoft}"
                                               FontFamily="IBM Plex Mono"
                                               FontSize="11" />
                                    <ItemsControl ItemsSource="{Binding KnowledgeSourceSummaries}"
                                                  Margin="0,0,0,12">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Margin="0,0,0,8"
                                                           Foreground="{StaticResource BrushMuted}"
                                                           TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ItemsControl ItemsSource="{Binding ImportedDocumentSummaries}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Panel}">
                                <StackPanel>
                                    <TextBlock Text="Learning Topics" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding LearningProfileSummary}"
                                               Margin="0,6,0,12"
