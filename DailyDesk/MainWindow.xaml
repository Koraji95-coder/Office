                                            <Button Content="Approve only" Background="#241A10" BorderBrush="{StaticResource BrushCopper}" Command="{Binding AcceptSuggestedActionCommand}" CommandParameter="{Binding SelectedInboxSuggestion}" Visibility="{Binding ShowApprovalDecisionActions, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <Button Content="Approve &amp; queue" Background="#241A10" BorderBrush="{StaticResource BrushCopper}" Command="{Binding ApproveAndQueueSuggestedActionCommand}" CommandParameter="{Binding SelectedInboxSuggestion}" Visibility="{Binding ShowApproveAndQueueAction, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <Button Content="Approve &amp; run" Background="#241A10" BorderBrush="{StaticResource BrushCopper}" Command="{Binding ApproveAndRunSuggestedActionCommand}" CommandParameter="{Binding SelectedInboxSuggestion}" Visibility="{Binding ShowApproveAndRunAction, Converter={StaticResource BoolToVisibilityConverter}}" />
